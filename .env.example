# The public base URL of this site. Drives the QR code, canonical URL,
# Open Graph tags, sitemap, robots and structured data.
#
# Development (Vercel preview):
#   NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
# Production (after buying a domain) — change this ONE line:
#   NEXT_PUBLIC_SITE_URL=https://jaipuriodhani.com
NEXT_PUBLIC_SITE_URL= https://av-links.vercel.app
# ----------------------------------------------------------------------
# Analytics (all optional — leave unset and the site still works).
# The analytics wrapper auto-detects whichever provider is present.
# ----------------------------------------------------------------------
# Google Analytics 4
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Plausible (self-hosted or cloud) — set the domain you registered
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=jaipuriodhani.com
# Umami
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
